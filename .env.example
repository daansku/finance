# Copy to .env and fill in what you need. Never commit .env.

# --- LLM provider -------------------------------------------------------
# Suggested setups:
#   - OpenRouter (one key, many models):  set OPENROUTER_API_KEY below.
#   - Ollama (fully local):               no key needed, runs on
#                                          http://localhost:11434/v1
# Add whatever else you need.
OPENROUTER_API_KEY=

# --- Corpus download ----------------------------------------------------
# Override if you fork the repo and host the release elsewhere.
TAXXA_DATA_RELEASE=https://github.com/Taxxa-AI/aalto-hackaton-2026/releases/download/data-v1

# --- Performance / hardware ---------------------------------------------
# Device for embedding & reranker models: cpu (default, safe), cuda, mps.
# Defaults to 'cpu' to prevent GPU/CPU overheating on laptops.
TAXXA_DEVICE=cpu

# Max CPU threads for PyTorch & BLAS libraries (default: 4).
# Lower this if your CPU still runs hot during 'load'.
TAXXA_NUM_THREADS=4

# --- Optional: Neo4j ----------------------------------------------------
# Only needed if you `docker compose up` the graph store. Defaults match
# the docker-compose.yml in this repo.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
