  "chapters": [],
  "sections": [
    {
      "id": "0d49a194-434d-4b87-b251-d4549d2c62b5",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 §",
      "text": "Suomessa siirrytään kesäaikaan vuoden 2002 alusta lukien kunkin vuoden maaliskuun viimeisenä sunnuntaina ja vastaavasti normaaliaikaan kunkin vuoden lokakuun viimeisenä sunnuntaina.",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "371/1992"
    },
    {
      "id": "cb9f03a2-ff9a-49dc-98d8-d049851741f0",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 §",
      "text": "Kesäaika on kolme tuntia edellä mittayksikköasetuksen (371/1992) 12 §:n 2 momentissa mainittua koordinoitua yleisaikaa.",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "371/1992"
    },
    {
      "id": "5d3eb0bb-5ec9-46e4-b5b3-a96b67bd785c",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 §",
      "text": "Kesäaika alkaa maaliskuun viimeisenä sunnuntaina kello 03.00, jolloin kelloa siirretään tunti eteenpäin. Kesäaika päättyy lokakuun viimeisenä sunnuntaina kello 04.00, jolloin kelloa siirretään tunti taaksepäin.",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "371/1992"
    },
    {
      "id": "ba767097-826f-4287-9e73-67fa0f01c921",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "4 §",
      "text": "Tämä asetus tulee voimaan 1 päivänä tammikuuta 2002.",
      "section_number": "4",
      "chapter_number": 1,
      "statute_id": "371/1992"
    }
  ],
