  "chapters": [],
  "sections": [
    {
      "id": "aaa67ce6-2cb0-421c-aca9-03f93350577a",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 §",
      "text": "Muu kuin 1 momentissa tarkoitettu hakemus on tehtävä kirjallisesti. Hakemuksesta on käytävä ilmi:",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "778/1985"
    },
    {
      "id": "38aadbe0-d15e-4718-93b2-de2e7aa31107",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 §",
      "text": "Elinkeinonharjoittajasta merkitään kaupparekisterin mukainen toiminimi ja yritys- ja yhteisötunnus.",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "778/1985"
    },
    {
      "id": "f92f0ca7-6dea-4c91-a672-cd4375a3d71f",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "17 §",
      "text": "Yrityskiinnitysrekisteriä pidetään elinkeinonharjoittajan yritys- ja yhteisötunnuksen mukaisessa järjestyksessä. Ennen yritys- ja yhteisötietolain (244/2001) voimaantuloa tehtyjen rekisteröintien osalta rekisteriä voidaan pitää lain voimaan tullessa voimassa olleen elinkeinonharjoittajan kaupparekisterinumeron mukaisessa järjestyksessä. Tämä asetus tulee voimaan 1 päivänä huhtikuuta 2001.",
      "section_number": "17",
      "chapter_number": 1,
      "statute_id": "778/1985"
    }
  ],
  "clauses": [
    {
      "id": "de91ad70-17d2-4a8d-aabe-2b8970c30261",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 1",
      "text": "1) hakijan ja tämän asiamiehen nimi ja osoite;",
      "clause_number": 1,
      "section_number": "1",
      "statute_id": "778/1985"
    },
    {
      "id": "75e5ba9e-37ff-4a96-91ad-f69a2d864126",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 2",
      "text": "2) hakijan vaatimus; ja",
      "clause_number": 2,
      "section_number": "1",
      "statute_id": "778/1985"
    },
    {
      "id": "3ca4b5a3-417f-4a87-9d29-a304960f0ea1",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 3",
      "text": "3) sen elinkeinonharjoittajan kaupparekisterin mukainen toiminimi ja yritys- ja yhteisötunnus, jonka omaisuutta hakemus koskee.",
      "clause_number": 3,
      "section_number": "1",
      "statute_id": "778/1985"
    }
  ],
