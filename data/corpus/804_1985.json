      "publisher": "finlex",
      "title": "1 §",
      "text": "Nimilautakunnan tehtävänä on: Nimilautakunta on oikeusministeriön alainen. Tämä asetus tulee voimaan 1 päivänä kesäkuuta 1999.",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "804/1985"
    }
  ],
  "clauses": [
    {
      "id": "9353f2ec-da81-4094-beb2-c3e0a0e627df",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 1",
      "text": "1) antaa tuomioistuimille, maistraateille ja muille viranomaisille lausuntoja suku- ja etunimeä koskevissa asioissa;",
      "clause_number": 1,
      "section_number": "1",
      "statute_id": "804/1985"
    },
    {
      "id": "0b766f2e-d159-4504-8af9-8627ae1a82ee",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 2",
      "text": "2) seurata suku- ja etunimeä koskevissa asioissa noudatettua käytäntöä sekä antaa siitä tietoja tuomioistuimille, maistraateille ja muille viranomaisille;",
      "clause_number": 2,
      "section_number": "1",
      "statute_id": "804/1985"
    },
    {
      "id": "479fb322-5fa7-4b7b-9bb0-4494ba361116",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 3",
      "text": "3) tehdä oikeusministeriölle aloitteita ja esityksiä suku- ja etunimeä koskevan lainsäädännön kehittämiseksi.",
      "clause_number": 3,
      "section_number": "1",
      "statute_id": "804/1985"
    }
  ],
