  "chapters": [],
  "sections": [
    {
      "id": "5251a9a3-5def-4d39-8282-cb3cfafdd8a1",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 § Soveltamisala",
      "text": "Tässä asetuksessa säädetään ympäristöministeriön maksullisista suoritteista, niiden maksuperusteista sekä eräistä julkisoikeudellisista suoritteista perittävistä kiinteistä maksuista.",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "15/1992"
    },
    {
      "id": "1c3ca3ae-e54c-40db-a853-d1f01c97a5ea",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 § Julkisoikeudelliset suoritteet, joista peritään omakustannusarvon mukainen maksu",
      "text": "Valtion maksuperustelain 6 §:ssä tarkoitettuja julkisoikeudellisia suoritteita, joista peritään suoritteen omakustannusarvon mukainen maksu, ovat: Maksu määräytyy suoritteen tuottamiseen käytettyjen työtuntien perusteella. Asiantuntijatyöstä peritään 78 euroa työtunnilta ja avustavasta toimistotyöstä 42 euroa työtunnilta. Lisäksi peritään tyyppihyväksyntähakemuksen käsittelystä aiheutuvat matkakustannukset valtion virka- ja työehtosopimuksen mukaisesti.",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "15/1992"
    },
    {
      "id": "6633b1c4-fcde-4d4b-8e0c-94c273933599",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 § Julkisoikeudelliset suoritteet, joista peritään kiinteä maksu",
      "text": "Valtion maksuperustelain 6 §:ssä tarkoitettuja julkisoikeudellisia suoritteita, joista peritään keskimääräiseen omakustannusarvoon perustuva tai 6 §:n 3 momentin perusteella omakustannusarvoa alempi maksu, ovat: Edellä kohdissa 3―5 tarkoitettua maksua valituspäätöksestä ei kuitenkaan peritä Muut julkisoikeudelliset suoritteet:",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "15/1992"
    },
    {
      "id": "64a821c0-3167-49ca-b3f4-9b1fbc8dd183",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "4 § Muut suoritteet",
      "text": "Maksullisia suoritteita, jotka hinnoitellaan liiketaloudellisin perustein, ovat seuraavat tilaukseen tai muuhun toimeksiantoon perustuvat palvelut tai muut suoritteet: Viranomaisten toiminnan julkisuudesta annetun lain 34 §:n 2 momentissa tarkoitetusta tiedon esille hakemisesta sekä saman lain 34 §:n 3 momentissa tarkoitettujen kopioiden ja tulosteiden antamisesta perittävistä maksuista päättää ympäristöministeriö ottaen huomioon, mitä viranomaisten toiminnan julkisuudesta annetun lain 34 §:ssä säädetään.",
      "section_number": "4",
      "chapter_number": 1,
      "statute_id": "15/1992"
    },
    {
      "id": "a1e51191-b35c-49fc-ac60-79849db4f24d",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "5 § Voimaantulo",
      "text": "Tämä asetus tulee voimaan 1 päivänä tammikuuta 2007 ja on voimassa vuoden 2009 loppuun saakka. Päätöksistä asiassa, joka on tullut vireille ennen tämän asetuksen voimaantuloa, peritään maksu silloin voimassa olleiden säännösten mukaisesti.",
      "section_number": "5",
      "chapter_number": 1,
      "statute_id": "15/1992"
    }
  ],
  "clauses": [
