      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 4",
      "text": "4) muutos, joka halutaan merkittävän tavaramerkkirekisteriin.",
      "clause_number": 4,
      "section_number": "1",
      "statute_id": "544/2019"
    },
