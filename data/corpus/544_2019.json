    {
      "id": "bb94fade-a035-4c09-88d2-62368068cff3",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 § Muutospyynnöt",
      "text": "Patentti- ja rekisterihallitukselle osoitetun tavaramerkkihakemukseen ja rekisteröintiin kohdistuvan muutosta koskevan pyynnön tulee sisältää: Jos kyse on tavaramerkkilain (544/2019) 25 §:n mukaisesta merkin muuttamisesta, pyyntöön on liitettävä mainitun lain 16 §:n 2 momentin 3 kohdassa tarkoitettu merkin kuvaus.",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "544/2019"
    },
    {
      "id": "d3389db2-cdfe-4dda-8c0a-1a806537ebb2",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 § Luovutuksen merkitseminen tavaramerkkirekisteriin",
      "text": "Patentti- ja rekisterihallitukselle osoitetun tavaramerkkilain 38 §:n 1 momentin mukaisen pyynnön luovutuksen merkitsemiseksi tavaramerkkirekisteriin tulee sisältää:",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "544/2019"
    },
    {
      "id": "ef223635-b598-4b35-85c6-93fc0ef70e53",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 § Panttauksen merkitseminen tavaramerkkirekisteriin",
      "text": "Patentti- ja rekisterihallitukselle osoitetun tavaramerkkilain 40 §:n 1 momentin mukaisen pyynnön panttauksen merkitsemiseksi tavaramerkkirekisteriin tulee sisältää:",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "544/2019"
    },
    {
      "id": "32917ec0-d129-4558-8a70-b650f943db32",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "4 § Lisenssin merkitseminen tavaramerkkirekisteriin",
      "text": "Patentti- ja rekisterihallitukselle osoitetun tavaramerkkilain 43 §:n 1 momentin mukaisen pyynnön lisenssin merkitsemiseksi tavaramerkkirekisteriin tulee sisältää:",
      "section_number": "4",
      "chapter_number": 1,
      "statute_id": "544/2019"
    },
    {
      "id": "5a540084-d6ce-4cef-b829-8e926496fd19",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "5 § Rekisteröinnin uudistaminen",
      "text": "Tavaramerkkilain 30 §:n 2 momentin mukaisen paperisen uudistamishakemuksen tulee sisältää:",
      "section_number": "5",
      "chapter_number": 1,
      "statute_id": "544/2019"
    },
    {
      "id": "45bbfd47-2d98-4c5a-9857-dcbbc1e66f5a",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "6 § Voimaantulo",
      "text": "Tämä asetus tulee voimaan 15 päivänä heinäkuuta 2019. Tätä asetusta sovelletaan sen voimaantulon jälkeen vireille tulleisiin hakemuksiin ja pyyntöihin.",
      "section_number": "6",
      "chapter_number": 1,
      "statute_id": "544/2019"
    }
  ],
  "clauses": [
    {
      "id": "42707c8b-75a7-411a-81c4-dcf1b5f057bf",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 1",
      "text": "1) pyynnön esittäjän tunnistetiedot;",
      "clause_number": 1,
      "section_number": "1",
      "statute_id": "544/2019"
    },
    {
      "id": "b4ca7a4c-1bb5-4fca-a020-1fc22342a70f",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 2",
      "text": "2) sen tavaramerkkihakemuksen hakemusnumero tai tavaramerkin rekisteröintinumero, johon pyyntö kohdistuu;",
      "clause_number": 2,
      "section_number": "1",
      "statute_id": "544/2019"
    },
    {
      "id": "c5c31375-887e-40fe-b5da-2b902cdf487c",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 3",
      "text": "3) luettelo tavaroista tai palveluista, joita pyyntö koskee, jos se ei koske kaikkia tavaramerkkihakemuksen tai rekisteröinnin kattamia tavaroita tai palveluja;",
      "clause_number": 3,
      "section_number": "1",
      "statute_id": "544/2019"
    },
    {
