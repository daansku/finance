    "title": "Valtioneuvoston asetus kulttuuriesineiden maastaviennin rajoittamisesta",
    "text": "Valtioneuvoston asetus kulttuuriesineiden maastaviennin rajoittamisesta",
    "statute_id": "933/2016",
    "finlex_url": "https://finlex.fi/fi/laki/ajantasa/933/2016"
  },
  "chapters": [],
  "sections": [
    {
      "id": "5b2145fd-16f6-466a-a25e-ae8594005317",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 § Vientilupalomakkeen sisältö",
      "text": "Museoviraston vahvistaman vientilupaa koskevan lomakkeen tulee sisältää seuraavat tiedot:",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "933/2016"
    },
    {
      "id": "e21c9284-b8d4-4863-884c-b4294678159d",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 § Vientilupahakemukseen liitettävät tiedot",
      "text": "Vientilupaa koskevaan hakemukseen on liitettävä: Edellä 1 momentissa säädetyn lisäksi lupahakemukseen on liitettävä perinnönjakokirja tai ositussopimus, jos vientilupaa haetaan kulttuuriesineiden maastaviennin rajoittamisesta annetun lain (933/2016) 8 §:n 3 momentin 2 kohdan perusteella.",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "933/2016"
    },
    {
      "id": "e948bd96-5f02-4c30-af80-68ffd92334b3",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 § Voimaantulo",
      "text": "Tämä asetus tulee voimaan 1 päivänä lokakuuta 2017.",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "933/2016"
    }
  ],
  "clauses": [
    {
      "id": "f13f2524-8d8f-471a-9e9e-f646279bdd21",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 1",
      "text": "1) hakijan nimi ja yhteystiedot;",
      "clause_number": 1,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "3b6859a5-a42e-4f1d-b704-2a8a22341a81",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 2",
      "text": "2) kulttuuriesineen omistajan nimi ja yhteystiedot;",
      "clause_number": 2,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "f5dbb200-b484-470c-a08b-23fb29e9bbdf",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 3",
      "text": "3) maa, johon kulttuuriesine on tarkoitus viedä;",
      "clause_number": 3,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "af9e49b3-12f6-4fff-b484-4c018ad347b4",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 4",
      "text": "4) kulttuuriesineen valmistusaika ja -paikka, valmistusmateriaali, tekijä tai valmistaja sekä kulttuuriesineen historia ja Suomessa oloaika;",
      "clause_number": 4,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "5f5f0ea1-014c-444c-8e13-a1e1d87dd84d",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 5",
      "text": "5) kuuluuko kulttuuriesine ulkomaille muuttavan henkilön koti-irtaimistoon;",
      "clause_number": 5,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "006dec8b-dc2d-48a3-bbcc-281df299110c",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 6",
      "text": "6) onko ulkomailla asuva henkilö saanut kulttuuriesineen perintönä tai osituksen nojalla;",
      "clause_number": 6,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "69eb46dc-6429-4f97-a2a8-8788ddb2ee74",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 7",
      "text": "7) haetaanko lupaa määräajaksi ja hakijan esitys kulttuuriesineen Suomeen palauttamisajankohdaksi;",
      "clause_number": 7,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "3fcf6cff-a5e3-494d-ba8f-8916bd97c90c",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 1 mom 8",
      "text": "8) onko kulttuuriesineelle annettu väliaikainen maastavientikielto.",
      "clause_number": 8,
      "section_number": "1",
      "statute_id": "933/2016"
    },
    {
      "id": "af275a8d-5646-4379-84cb-c95d46a65b78",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 1",
      "text": "1) valtuutus kulttuuriesineen maastavientiin, jos vientilupaa hakee muu kuin kulttuuriesineen omistaja;",
      "clause_number": 1,
      "section_number": "2",
      "statute_id": "933/2016"
    },
    {
      "id": "75a6ade5-839e-4795-81a2-387c2a4ce5f6",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 2",
      "text": "2) valokuva kulttuuriesineestä.",
      "clause_number": 2,
      "section_number": "2",
      "statute_id": "933/2016"
    }
  ],
