  "chapters": [],
  "sections": [
    {
      "id": "6b040632-485b-484b-8c05-dfbf9ac6332b",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 § Omakustannusarvon mukaiset kiinteämaksuiset julkisoikeudelliset suoritteet",
      "text": "Ajoneuvohallintokeskus perii omakustannusarvon mukaisen, tämän asetuksen liitteessä määrätyn kiinteän maksun seuraavista suoritteista:",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "1010/2005"
    },
    {
      "id": "e4f2ae3d-848e-4f4a-b703-016ef9eef986",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "4 § Omakustannusarvosta poikkeavat kiinteämaksuiset julkisoikeudelliset suoritteet",
      "text": "Ajoneuvohallintokeskus perii omakustannusarvoa korkeamman kiinteän maksun seuraavista suoritteista: Tämä asetus tulee voimaan 1 päivänä heinäkuuta 2007. Asetuksen 2 §:n 16 kohta ja liitteen 16 kohta tulevat kuitenkin voimaan 1 päivänä elokuuta 2007. Liite M A K S U T A U L U K K O MAKSUASETUKSEN 2 §",
      "section_number": "4",
      "chapter_number": 1,
      "statute_id": "1010/2005"
    }
  ],
  "clauses": [
    {
      "id": "ac761228-be8b-4a30-8735-f18b51f8ec9f",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 1",
      "text": "1) ajoneuvon, osan, järjestelmän ja erillisen teknisen yksikön tyyppihyväksyntä;",
      "clause_number": 1,
      "section_number": "2",
      "statute_id": "1010/2005"
    },
    {
      "id": "6c9020bc-d4e1-4522-aea3-d0dc1960d439",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 2",
      "text": "2) ajoneuvotekniset lausunnot, luvat ja muut kuin 1 kohdassa tarkoitetut hyväksymiset;",
      "clause_number": 2,
      "section_number": "2",
      "statute_id": "1010/2005"
    },
    {
