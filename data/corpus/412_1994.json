    "title": "Asetus merentutkimuslaitoksesta annetun asetuksen muuttamisesta",
    "text": "Asetus merentutkimuslaitoksesta annetun asetuksen muuttamisesta",
    "statute_id": "412/1994",
    "finlex_url": "https://finlex.fi/fi/laki/ajantasa/412/1994"
  },
  "chapters": [],
  "sections": [
    {
      "id": "b9cc184b-677a-4994-b44a-606df0515c5c",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "4 §",
      "text": "Liikenneministeriö asettaa kolmeksi vuodeksi kerrallaan johtokunnan, johon kuuluu enintään seitsemän jäsentä. Yksi jäsenistä on laitoksen ylijohtaja ja yksi laitoksen henkilöstön edustaja. Liikenneministeriö määrää yhden jäsenistä puheenjohtajaksi ja yhden varapuheenjohtajaksi.",
      "section_number": "4",
      "chapter_number": 1,
      "statute_id": "412/1994"
    },
    {
      "id": "1fa7a375-83ef-41d7-822c-e2446872e3b7",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "5 §",
      "text": "Johtokunnan tehtävänä on:",
      "section_number": "5",
      "chapter_number": 1,
      "statute_id": "412/1994"
    },
    {
      "id": "418e4262-752c-4b43-9c28-5b451237c4d6",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "7 §",
      "text": "Johtokunta on päätösvaltainen, kun kokouksessa on läsnä puheenjohtajan tai varapuheenjohtajan lisäksi kolme jäsentä.",
      "section_number": "7",
      "chapter_number": 1,
      "statute_id": "412/1994"
    },
    {
      "id": "9f924835-3af9-43dd-ba4d-4d5c676b8cbd",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "12 §",
      "text": "Ylijohtajan nimittää valtioneuvosto. Tämä asetus tulee voimaan 1 päivänä tammikuuta 2000. Ennen asetuksen voimaantuloa voidaan ryhtyä asetuksen täytäntöönpanon edellyttämiin toimenpiteisiin.",
      "section_number": "12",
      "chapter_number": 1,
      "statute_id": "412/1994"
    }
  ],
  "clauses": [
    {
      "id": "a4b9492b-eddf-403b-9445-a42a3ccd5969",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 5 mom 1",
      "text": "1) päättää laitoksen toiminnan tavoitteista, talousarvioehdotuksesta ja toiminta- ja taloussuunnitelmasta sekä hyväksyä tilinpäätös ja toimintakertomus;",
      "clause_number": 1,
      "section_number": "5",
      "statute_id": "412/1994"
    }
  ],
