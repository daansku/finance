      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 9",
      "text": "9) henkilön omaa eroa koskeva ilmoitus, joka perustuu todettuun rekisterimerkintärikokseen;",
      "clause_number": 9,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
