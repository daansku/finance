      "publisher": "finlex",
      "title": "§ 3 mom 1",
      "text": "1) Patentti- ja rekisterihallituksen rekistereihin merkittyjen oikeuksien lakkaamisilmoitukset;",
      "clause_number": 1,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
      "id": "888588ca-8518-49da-9646-0d7c93eb5e13",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 2",
      "text": "2) viranomaisen lähettämän tiedonannon merkitseminen Patentti- ja rekisterihallituksen pitämiin rekistereihin;",
      "clause_number": 2,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
      "id": "85d79af1-5dcb-4ba5-9b86-73e70a259e4c",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 3",
      "text": "3) Patentti- ja rekisterihallituksen antamat vastaanottotodistukset;",
      "clause_number": 3,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
      "id": "a78905f6-4b43-47ad-802d-8e17450b9188",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 4",
      "text": "4) tilinpäätöstietojen julkistaminen;",
      "clause_number": 4,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
      "id": "60282af2-dfe7-495c-812a-899a33e3c5f9",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 5",
      "text": "5) osoitteenmuutoksen merkitseminen Patentti- ja rekisterihallituksen tai teollisoikeusasiamieslautakunnan ylläpitämiin rekistereihin;",
      "clause_number": 5,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
      "id": "33acf001-dc97-4584-bda9-1c48325649ae",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 6",
      "text": "6) elinkeinotoiminnan lopettamista tai yhteisön purkautumista koskeva ilmoitus Patentti- ja rekisterihallituksen rekisteriin sekä niihin liittyvät lopputilitysilmoitukset;",
      "clause_number": 6,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
      "id": "b15e671a-6940-42e4-8875-e7dd45db724e",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 7",
      "text": "7) jäljennös yhtiöjärjestyksestä, säännöistä ja yhtiösopimuksesta sekä ote kaupparekisteristä, jotka Patentti- ja rekisterihallitus antaa perus- tai muutosilmoituksen rekisteröinnin yhteydessä;",
      "clause_number": 7,
      "section_number": "3",
      "statute_id": "696/2014"
    },
    {
      "id": "98015644-0b14-45b3-9865-d49248a82b37",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 3 mom 8",
      "text": "8) yrityskiinnityksen kuolettaminen;",
      "clause_number": 8,
      "section_number": "3",
      "statute_id": "696/2014"
    },
