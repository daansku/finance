    {
      "id": "51ad17f2-4ffc-45e2-8204-c62b23cd0926",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 §",
      "text": "Abidjanissa 26 päivänä elokuuta 2021 tehdyn Maailman postiliiton yleissopimuksen lainsäädännön alaan kuuluvat määräykset ovat lakina voimassa sellaisina kuin Suomi on niihin sitoutunut.",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "55/2024"
    },
    {
      "id": "9f94871d-d503-48fa-8531-aea8c1f91ae2",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 §",
      "text": "Yleissopimuksen muiden kuin lainsäädännön alaan kuuluvien määräysten voimaansaattamisesta säädetään valtioneuvoston asetuksella.",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "55/2024"
    },
    {
      "id": "dc542360-9384-41ea-af71-a6ebbf22d516",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 §",
      "text": "Tämän lain voimaantulosta säädetään valtioneuvoston asetuksella. Tämä laki on voimassa A:n55/2024mukaisesti 1.2.2024 alkaen.",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "55/2024"
    }
  ],
