    "title": "Valtioneuvoston asetus Maailman postiliiton yleissopimuksesta",
    "text": "Valtioneuvoston asetus Maailman postiliiton yleissopimuksesta",
    "statute_id": "244/2019",
    "finlex_url": "https://finlex.fi/fi/laki/ajantasa/244/2019"
  },
  "chapters": [],
  "sections": [
    {
      "id": "5c6116b2-a0c3-4e2e-9847-b49f4cbe5489",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 §",
      "text": "Istanbulissa 6 päivänä lokakuuta 2016 tehty Maailman postiliiton yleissopimus on voimassa 1 päivästä tammikuuta 2018 niin kuin siitä on sovittu. Eduskunta on hyväksynyt yleissopimuksen 10 päivänä joulukuuta 2018 ja tasavallan presidentti 22 päivänä helmikuuta 2019. Hyväksymisestä on ilmoitettu Maailman postiliitolle 3 päivänä kesäkuuta 2019.",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "244/2019"
    },
    {
      "id": "f67c178a-7687-43e5-a82e-f22dd4620e17",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 §",
      "text": "Yleissopimuksen muut kuin lainsäädännön alaan kuuluvat määräykset ovat asetuksena voimassa.",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "244/2019"
    },
    {
      "id": "72382810-790c-4f78-a37b-f2c78517ab76",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 §",
      "text": "Maailman postiliiton yleissopimuksesta annettu laki (244/2019) tulee voimaan 15 päivänä heinäkuuta 2019. Ahvenanmaan maakuntapäivät on hyväksynyt lain voimaantulon maakunnassa.",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "244/2019"
    },
    {
      "id": "b697c72b-39df-4adb-988b-702ba8ff0f83",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "4 §",
      "text": "Tämä asetus tulee voimaan 15 päivänä heinäkuuta 2019.",
      "section_number": "4",
      "chapter_number": 1,
      "statute_id": "244/2019"
    }
  ],
