      "publisher": "finlex",
      "title": "§ 4 mom 2",
      "text": "2) toimiluvan haltijan, kuljettajantutkinnon vastaanottajan tai ajolupakokeen vastaanottajan päätöksestä tehdyn oikaisuvaatimuksen ratkaisu 42 euroa;",
      "clause_number": 2,
      "section_number": "4",
      "statute_id": "1021/2003"
    },
