      "publisher": "finlex",
      "title": "§ 4 mom 1",
      "text": "1) toimiluvan mukaisen katsastustoiminnan aloittamistarkastus 200 euroa;",
      "clause_number": 1,
      "section_number": "4",
      "statute_id": "1021/2003"
    },
