  "chapters": [],
  "sections": [
    {
      "id": "08d9941e-f4d0-4e2e-913d-f6daab027a4e",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "2 § Omakustannusarvon mukaiset kiinteämaksuiset julkisoikeudelliset suoritteet",
      "text": "Ajoneuvohallintokeskus perii omakustannusarvon mukaisen, tämän asetuksen liitteessä määrätyn kiinteän maksun seuraavista suoritteista:",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "1021/2003"
    },
    {
      "id": "f4c33252-2396-4045-99c4-ed62181c1db8",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "4 § Omakustannusarvosta poikkeavat kiinteä- maksuiset julkisoikeudelliset suoritteet",
      "text": "Ajoneuvohallintokeskus perii omakustannusarvoa alemman kiinteän maksun seuraavista suoritteista: Tämä asetus tulee voimaan 1 päivänä tammikuuta 2005. Liite M A K S U T A U L U K K O MAKSUASETUKSEN 2 §",
      "section_number": "4",
      "chapter_number": 1,
      "statute_id": "1021/2003"
    }
  ],
  "clauses": [
    {
      "id": "19035c69-5280-409b-8c8b-5a27cc9ff9c7",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 1",
      "text": "1) ajoneuvon, osan, järjestelmän ja erillisen teknisen yksikön tyyppihyväksyntä;",
      "clause_number": 1,
      "section_number": "2",
      "statute_id": "1021/2003"
    },
    {
      "id": "6c6ad318-f982-46e1-ad16-87f4aafab430",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 2",
      "text": "2) ajoneuvotekniset lausunnot, luvat ja muut kuin 1 kohdassa tarkoitetut hyväksymiset;",
      "clause_number": 2,
      "section_number": "2",
      "statute_id": "1021/2003"
    },
    {
      "id": "89e6840a-6794-4096-b637-be52f511403f",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 3",
      "text": "3) liikennetarvikkeiden kauppaan sekä asennus- ja korjaustoimintaan liittyvät suoritteet;",
      "clause_number": 3,
      "section_number": "2",
      "statute_id": "1021/2003"
    },
    {
      "id": "8508bd85-b6b8-480e-a72e-e0501e57d6a4",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 4",
      "text": "4) autokiinnityssuoritteet;",
      "clause_number": 4,
      "section_number": "2",
      "statute_id": "1021/2003"
    },
    {
      "id": "0c7965fe-0a53-4c26-8419-e57cabbfa98a",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 2 mom 5",
      "text": "5) ajoneuvojen rekisteröintisuoritteet;",
      "clause_number": 5,
      "section_number": "2",
      "statute_id": "1021/2003"
