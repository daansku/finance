      "title": "2 § Ministeriön toimialan virastot, laitokset, toimielimet ja yhteisöt",
      "text": "Sosiaali- ja terveysministeriön toimialaan kuuluvat:",
      "section_number": "2",
      "chapter_number": 1,
      "statute_id": "491/2017"
    },
    {
      "id": "70027110-febc-4e8c-98ee-170efe1bfda9",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "3 § Ministeriön organisaatio",
      "text": "Osastojen ulkopuolella ovat erillisyksiköinä strategia- ja talousyksikkö, henkilöstö- ja hallintoyksikkö, viestintäyksikkö ja kansainvälisten asioiden yksikkö.",
      "section_number": "3",
      "chapter_number": 1,
      "statute_id": "491/2017"
    },
    {
      "id": "2eca2e1d-ec65-4b7b-bef1-e7c06c09e9e9",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "6 § Johtavat virkamiehet",
      "text": "Ministeriössä on kansliapäällikkö. Osaston päällikkönä toimii osastopäällikkö. Osaston päälliköllä on ylijohtajan arvonimi. Tämä asetus tulee voimaan 1 päivänä tammikuuta 2023.",
      "section_number": "6",
      "chapter_number": 1,
      "statute_id": "491/2017"
    }
  ],
