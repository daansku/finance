{
  "statute": {
    "id": "6c2cc4e1-c483-439c-88b9-3d232eea88a1",
    "node_type": "Statute",
    "publisher": "finlex",
    "title": "Asetus panostaja-asetuksen muuttamisesta",
    "text": "Asetus panostaja-asetuksen muuttamisesta",
    "statute_id": "409/1986",
    "finlex_url": "https://finlex.fi/fi/laki/ajantasa/409/1986"
  },
  "chapters": [],
  "sections": [
    {
      "id": "bfeea445-d633-4b58-85e2-790fc0130144",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "1 §",
      "text": "Työsuojelusta ja sen valvonnasta vastaava ministeriö, jäljempänä ministeriö, antaa hakemuksesta tässä asetuksessa säädetyt ehdot täyttävälle henkilölle panostajan pätevyyskirjan.",
      "section_number": "1",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "2336a394-6d48-4a31-b1c1-9be7850426d1",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "5 §",
      "text": "Räjäyttäjän pätevyyskirjan saamiseksi vaaditaan:",
      "section_number": "5",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "238a3a1c-1ac0-4ac9-8201-6e091169cd0e",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "6 §",
      "text": "Nuoremman panostajan pätevyyskirjan saamiseksi vaaditaan:",
      "section_number": "6",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "c6a45922-60ce-486f-9d92-1b8901877a51",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "7 §",
      "text": "Vanhemman panostajan pätevyyskirjan saamiseksi vaaditaan:",
      "section_number": "7",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "03fed469-85f5-4fe5-a885-b2dfb4fdc802",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "8 §",
      "text": "Ylipanostajan pätevyyskirjan saamiseksi vaaditaan:",
      "section_number": "8",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "2d09f380-ac45-473b-9d7e-9895690caed9",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "9 §",
      "text": "Ministeriö vahvistaa 5―8 §:ssä tarkoitettujen kurssien opetussuunnitelmat.",
      "section_number": "9",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "c19ed8ca-cc56-400a-8adb-5faa7ef4af65",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "10 §",
      "text": "Ministeriö voi antaa 5―8 §:ssä tarkoitetun pätevyyskirjn diplomi-insinöörin, insinöörin, teknikon tai muun vastaavan teknisen tutkinnon suorittaneelle henkilölle:",
      "section_number": "10",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "6849705b-2f4b-4fc7-b1f4-599092b4e5e0",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "11 §",
      "text": "Panostajan pätevyyskirjaa on haettava kirjallisesti ministeriöltä. Hakemukseen on liitettävä lääkärintodistus, josta ilmenee, että hakija on terveydeltään panostajan tehtäviin sopiva, samoin kuin selvitys hakijan suorittamasta kurssista ja enintään kaksi vuotta aikaisemmin hyväksytystä tutkinnosta sekä selvitys vaadittavasta työkokemuksesta. Lääkärintodistus saa olla enintään kolme kuukautta aikaisemmin annettu.",
      "section_number": "11",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "1c8c895f-1a36-458a-a1b3-126967710ec0",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "12 §",
      "text": "Ministeriö voi, milloin todetaan, ettei pätevyyskirjan saaja enää täytä tässä asetuksessa edellytettyjä vaatimuksia, peruuttaa pätevyyskirjan joko kokonaan tai määräajaksi.",
      "section_number": "12",
      "chapter_number": 1,
      "statute_id": "409/1986"
    },
    {
      "id": "59c4c494-a113-434e-ae2c-927fc1e2d680",
      "node_type": "Section",
      "publisher": "finlex",
      "title": "13 §",
      "text": "Ministeriö vahvistaa pätevyyskirjan kaavan, pitää luetteloa annetuista pätevyyskirjoista ja vahvistaa kuulustelijalle suoritettavan maksun sekä antaa tarkempia säännöksiä tämän asetuksen täytäntöönpanosta. Tämä asetus tulee voimaan 1 päivänä huhtikuuta 1997.",
      "section_number": "13",
      "chapter_number": 1,
      "statute_id": "409/1986"
    }
  ],
  "clauses": [
    {
      "id": "3db48b3b-926f-4654-9eb1-ad48628f561d",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 5 mom 5",
      "text": "5) ministeriön hyväksymälle kuulustelijalle suoritettu räjäyttäjän kurssiin liittyvä tutkinto.",
      "clause_number": 5,
      "section_number": "5",
      "statute_id": "409/1986"
    },
    {
      "id": "88ffc0c6-e864-4635-823b-594739cf73f8",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 6 mom 5",
      "text": "5) ministeriön hyväksymälle kuulustelijalle suoritettu nuoremman panostajan kurssiin liittyvä tutkinto.",
      "clause_number": 5,
      "section_number": "6",
      "statute_id": "409/1986"
    },
    {
      "id": "5cb7b5b7-2d82-4fae-ac6f-5a3fa62866d7",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 7 mom 5",
      "text": "5) ministeriön hyväksymälle kuulustelijalle suoritettu vanhemman panostajan kurssiin liittyvä tutkinto.",
      "clause_number": 5,
      "section_number": "7",
      "statute_id": "409/1986"
    },
    {
      "id": "0ddb752c-681a-4a46-95ed-2cfb77039044",
      "node_type": "Clause",
      "publisher": "finlex",
      "title": "§ 8 mom 5",
      "text": "5) ministeriön hyväksymälle kuulustelijalle suoritettu ylipanostajan kurssiin liittyvä tutkinto.",
      "clause_number": 5,
      "section_number": "8",
      "statute_id": "409/1986"
    }
  ],
